```python
from fastapi import HTTPException
from sqlalchemy import select
from sqlalchemy.ext.asyncio import AsyncSession

from app.models import Contribution  # adjust import path as needed


async def check_duplicate_transaction_reference(
    reference: str,
    db: AsyncSession,
) -> None:
    """
    Raise HTTPException 400 if the given transaction_reference already exists in the database.
    Compares normalized (stripped) values.
    """
    stripped_ref = reference.strip()
    stmt = select(Contribution).where(Contribution.transaction_reference == stripped_ref)
    result = await db.execute(stmt)
    if result.scalars().first() is not None:
        raise HTTPException(
            status_code=400,
            detail="Duplicate transaction reference detected.",
        )
