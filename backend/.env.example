APP_ENV=production
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
JWT_SECRET=replace-with-a-random-32-plus-character-secret
CORS_ORIGINS=https://your-admin.vercel.app,https://your-mobile-web-origin.example
SQL_ECHO=false

# AI assistant (optional but required for live AI draft generation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Expo push notifications (required for production phone push delivery)
EXPO_ACCESS_TOKEN=

# Weekly emails / unsubscribe flow
WEEKLY_EMAILS_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Family Pledge <no-reply@example.org>

# Cloudinary signed uploads (optional media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
