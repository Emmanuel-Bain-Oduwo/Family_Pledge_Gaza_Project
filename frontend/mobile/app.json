{
  "expo": {
    "name": "Family Pledge",
    "slug": "family-pledge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B6B3A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.namlef.familypledge"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B6B3A"
      },
      "package": "org.namlef.familypledge"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0B6B3A"
        }
      ]
    ],
    "scheme": "familypledge",
    "extra": {
      "eas": {
        "projectId": "family-pledge-namlef"
      }
    }
  }
}
